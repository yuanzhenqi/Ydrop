# ─── 核心鉴权 ───
# Web 端和 Android 端访问 API 的 token，请用强随机字符串
RELAY_TOKEN=change-me

# ─── 公开地址（用于生成音频下载链接） ───
PUBLIC_BASE_URL=http://localhost:8787

# ─── AI 分析（可选） ───
# 填了就用 provider，没填走 heuristic 兜底
AI_PROVIDER_BASE_URL=
AI_PROVIDER_API_KEY=
AI_PROVIDER_MODEL=gpt-4.1-mini

# ─── SQLite（Web 端笔记存储） ───
SQLITE_DB_PATH=./storage/ydrop.db

# ─── WebDAV 同步（填了才启用） ───
WEBDAV_BASE_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
WEBDAV_FOLDER=ydoc/inbox
WEBDAV_SYNC_INTERVAL=300

# ─── 静态文件目录（Next.js 构建产物） ───
STATIC_DIR=./static

# ─── 临时文件上传（音频中转） ───
RELAY_STORAGE_DIR=./storage/temp
RELAY_METADATA_PATH=./storage/metadata.json
MAX_UPLOAD_MB=50
DEFAULT_TTL_MINUTES=1440
MAX_TTL_MINUTES=1440
CLEANUP_INTERVAL_SECONDS=600
