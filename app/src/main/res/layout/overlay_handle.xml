<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <View
        android:id="@+id/overlayHandle"
        android:layout_width="24dp"
        android:layout_height="84dp"
        android:background="#A7375D50" />

    <LinearLayout
        android:id="@+id/overlayPanel"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp"
        android:background="#FFFDFC"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="快速捕捉"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#18212B" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/overlayCategoryTodo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="待办"
                android:background="#F6E2BD"
                android:padding="10dp"
                android:textColor="#18212B" />

            <TextView
                android:id="@+id/overlayCategoryTask"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="任务"
                android:background="#DCEAF9"
                android:padding="10dp"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/overlayCategoryReminder"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="提醒"
                android:background="#F0D1D0"
                android:padding="10dp"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/overlayCategoryNote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="普通"
                android:background="#D9E2DC"
                android:padding="10dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <EditText
            android:id="@+id/overlayDraftInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:minHeight="96dp"
            android:gravity="top"
            android:hint="输入一条快速记录"
            android:backgroundTint="#C9D2D8" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/overlayPriorityLow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="低"
                android:background="#D9E2DC"
                android:padding="10dp" />

            <TextView
                android:id="@+id/overlayPriorityMedium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="中"
                android:background="#DCEAF9"
                android:padding="10dp"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/overlayPriorityHigh"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="高"
                android:background="#F6E2BD"
                android:padding="10dp"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/overlayPriorityUrgent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="紧急"
                android:background="#F0D1D0"
                android:padding="10dp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/overlayRecordingStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="按住录音键开始，松开停止保存" />

            <ImageButton
                android:id="@+id/overlayRecordButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:background="#00000000" />

            <ImageButton
                android:id="@+id/overlaySaveButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_save"
                android:background="#00000000" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="最近记录"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/overlayRecentNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</LinearLayout>
